datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(EMPLOYEE)
  departmentId String? // Optional department field (Phase 1)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}
