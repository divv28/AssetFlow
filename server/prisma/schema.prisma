datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           Int        @id @default(autoincrement())
  uuid         String     @unique @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(EMPLOYEE)
  
  departmentId String? // FK to Department
  department   Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Back relations
  headedDepartment   Department? @relation("DepartmentHead")
  createdDepartments Department[] @relation("DepartmentCreator")
  auditLogs          AuditLog[]
  createdAssets      Asset[]     @relation("AssetCreator")
  uploadedDocuments  AssetDocument[] @relation("DocumentUploader")
  statusChanges      AssetStatusHistory[] @relation("StatusChanger")
  allocatedAssets    Asset[]     @relation("AssetAllocation")

  @@map("users")
}

model Department {
  id                 String       @id @default(uuid())
  name               String       @unique
  code               String       @unique
  description        String?
  
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")
  
  headId             String?      @unique
  head               User?        @relation("DepartmentHead", fields: [headId], references: [uuid])
  
  status             UserStatus   @default(ACTIVE)
  
  createdById        String?
  creator            User?        @relation("DepartmentCreator", fields: [createdById], references: [uuid])
  
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?    // Soft delete marker

  employees          User[]       @relation("DepartmentEmployees")
  assets             Asset[]

  @@map("departments")
}

model Category {
  id                String     @id @default(uuid())
  name              String     @unique
  description       String?
  warrantyMonths    Int        @default(0)
  depreciationYears Int        @default(0)
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  assets            Asset[]

  @@map("categories")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [uuid])
  action     String   // e.g. "DEPARTMENT_CREATED", "EMPLOYEE_PROMOTED"
  entityType String   // e.g. "Department", "Category", "User"
  entityId   String
  metadata   Json     // before/after values or relevant details
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

model Asset {
  id              String         @id @default(uuid())
  assetTag        String         @unique
  name            String
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id])
  departmentId    String?
  department      Department?    @relation(fields: [departmentId], references: [id])
  serialNumber    String?        @unique
  qrCode          String         @unique
  acquisitionDate DateTime?
  acquisitionCost Decimal?       @db.Decimal(12, 2)
  manufacturer    String?
  vendor          String?
  condition       AssetCondition @default(NEW)
  location        String?
  isBookable      Boolean        @default(false)
  warrantyExpiry  DateTime?
  status          AssetStatus    @default(AVAILABLE)
  remarks         String?
  createdBy       String
  creator         User           @relation("AssetCreator", fields: [createdBy], references: [uuid])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?      // Soft delete marker
  allocatedToId   String?
  allocatedTo     User?          @relation("AssetAllocation", fields: [allocatedToId], references: [uuid])

  documents       AssetDocument[]
  statusHistory   AssetStatusHistory[]

  @@map("assets")
}

model AssetDocument {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  fileUrl    String
  fileType   String   // e.g. "photo", "invoice", "manual"
  uploadedBy String
  uploader   User     @relation("DocumentUploader", fields: [uploadedBy], references: [uuid])
  createdAt  DateTime @default(now())

  @@map("asset_documents")
}

model AssetStatusHistory {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  fromStatus String?
  toStatus   String
  changedBy  String
  changer    User     @relation("StatusChanger", fields: [changedBy], references: [uuid])
  reason     String?
  createdAt  DateTime @default(now())

  @@map("asset_status_histories")
}
